# ─── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# MongoDB connection string (Atlas or local).
MONGODB_URI=mongodb://127.0.0.1:27017/codebud

# JWT secret used to sign auth tokens. Change in production.
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=7d

# Optional: enable multi-instance realtime (Socket.io across replicas).
# Leave empty for single-instance (default).
REDIS_URL=

# ─── AI provider ─────────────────────────────────────────
# AI_PROVIDER: "anthropic" | "openai" | "mock"
# Leave as "mock" to run with no API key (returns canned but useful responses).
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
